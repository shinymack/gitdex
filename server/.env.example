# Server Config
PORT=3001
NODE_ENV=development

# Client URLs (comma separated)
CLIENT_URLS=http://localhost:3000,https://gitdex-alpha.vercel.app

# Redis
REDIS_URL=redis://localhost:6379

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_USERNAME=your_github_username
DOCS_REPO_OWNER=your_docs_repo_owner
DOCS_REPO_NAME=gitdex-docs

# AI
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key
DOCS_MODELS=gemma-4-31b-it,gemma-4-26b-a4b-it
CHAT_MODELS=gemma-4-26b-a4b-it,gemma-4-31b-it